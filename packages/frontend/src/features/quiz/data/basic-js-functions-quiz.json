    {
      "id": "e7f8a9b0-c1d2-4e3f-4a5b-6c7d8e9f0a1b",
      "step": 5,
      "question": "In an arrow function, if there is only one parameter, are parentheses optional?",
      "codeSnippet": "const double = n => n * 2;",
      "correctAnswerId": "0n1o2p3q-4r5s-4t6u-7v8w-9x0y1z2a3b4c",
      "explanation": "In arrow functions, you can omit the parentheses around the parameter list if and only if there is exactly one parameter.",
      "answers": [
        { "id": "0n1o2p3q-4r5s-4t6u-7v8w-9x0y1z2a3b4c", "text": "Yes, always" },
        { "id": "1o2p3q4r-5s6t-4u7v-8w9x-0y1z2a3b4c5d", "text": "No, never" },
        {
          "id": "2p3q4r5s-6t7u-4v8w-9x0y-1z2a3b4c5d6e",
          "text": "Only if using the 'return' keyword"
        },
        { "id": "3q4r5s6t-7u8v-4w9x-0y1z-2a3b4c5d6e7f", "text": "Only in strict mode" }
      ]
    },
    {
      "id": "f8e7d6c5-b4a3-4d2c-1b0a-9f8e7d6c5b4a",
      "step": 6,
      "question": "What is a 'parameter' in a function context?",
      "codeSnippet": null,
      "correctAnswerId": "5s6t7u8v-9w0x-4y1z-2a3b-4c5d6e7f8g9h",
      "explanation": "A parameter is the named variable listed in the function's definition, while an argument is the actual value passed to the function when it is called.",
      "answers": [
        {
          "id": "4r5s6t7u-8v9w-4x0y-1z2a-3b4c5d6e7f8g",
          "text": "The value passed during the call"
        },
        {
          "id": "5s6t7u8v-9w0x-4y1z-2a3b-4c5d6e7f8g9h",
          "text": "The variable name in the declaration"
        },
        { "id": "6t7u8v9w-0x1y-4z2a-3b4c-5d6e7f8g9h0i", "text": "The function's return type" },
        { "id": "7u8v9w0x-1y2z-4a3b-4c5d-6e7f8g9h0i1j", "text": "A reserved keyword" },
        { "id": "8v9w0x1y-2z3a-4b4c-5d6e-7f8g9h0i1j2k", "text": "The function's memory address" }
      ]
    },
    {
      "id": "b3c4d5e6-f7a8-4b9c-0d1e-2f3a4b5c6d7e",
      "step": 7,
      "question": "Which of these is a valid function expression?",
      "codeSnippet": null,
      "correctAnswerId": "0x1y2z3a-4b5c-4d6e-7f8g-9h0i1j2k3l4m",
      "explanation": "A function expression involves assigning a function (often anonymous) to a variable. 'const start = function() {};' is a classic example.",
      "answers": [
        { "id": "9w0x1y2z-3a4b-4c5d-6e7f-8g9h0i1j2k3l", "text": "function start() {}" },
        { "id": "0x1y2z3a-4b5c-4d6e-7f8g-9h0i1j2k3l4m", "text": "const start = function() {};" },
        { "id": "1y2z3a4b-5c6d-4e7f-8g9h-0i1j2k3l4m5n", "text": "start: function() {}" },
        { "id": "2z3a4b5c-6d7e-4f8g-9h0i-1j2k3l4m5n6o", "text": "new function start() {}" }
      ]
    },
    {
      "id": "a6b7c8d9-e0f1-4a2b-3c4d-5e6f7a8b9c0d",
      "step": 8,
      "question": "What happens to extra arguments passed to a function?",
      "codeSnippet": "function sum(a, b) {\n  return a + b;\n}\nsum(1, 2, 3, 4);",
      "correctAnswerId": "4b5c6d7e-8f9g-4h0i-1j2k-3l4m5n6o7p8q",
      "explanation": "JavaScript doesn't throw an error if you pass too many arguments. They aren't assigned to named parameters, but they are still accessible via the 'arguments' object or 'rest parameters'.",
      "answers": [
        { "id": "3a4b5c6d-7e8f-4g9h-0i1j-2k3l4m5n6o7p", "text": "Throws a SyntaxError" },
        {
          "id": "4b5c6d7e-8f9g-4h0i-1j2k-3l4m5n6o7p8q",
          "text": "Ignored, but stored in 'arguments'"
        },
        { "id": "5c6d7e8f-9g0h-4i1j-2k3l-4m5n6o7p8q9r", "text": "Function automatically expands" },
        { "id": "6d7e8f9g-0h1i-4j2k-3l4m-5n6o7p8q9r0s", "text": "Returns NaN" },
        { "id": "7e8f9g0h-1i2j-4k3l-4m5n-6o7p8q9r0s1t", "text": "The code won't compile" }
      ]
    },
    {
      "id": "f1a2b3c4-d5e6-4f7a-8b9c-0d1e2f3a4b5c",
      "step": 9,
      "question": "How do you define a default value for a parameter?",
      "codeSnippet": null,
      "correctAnswerId": "8f9g0h1i-2j3k-4l4m-5n6o-7p8q9r0s1t2u",
      "explanation": "ES6 introduced a concise syntax for default parameters using the assignment operator (=) directly in the function signature.",
      "answers": [
        { "id": "8f9g0h1i-2j3k-4l4m-5n6o-7p8q9r0s1t2u", "text": "function test(a = 10) {}" },
        { "id": "9g0h1i2j-3k4l-4m5n-6o7p-8q9r0s1t2u3v", "text": "function test(a : 10) {}" },
        { "id": "0h1i2j3k-4l5m-4n6o-7p8q-9r0s1t2u3v4w", "text": "function test(a) { a || 10 }" },
        { "id": "1i2j3k4l-5m6n-4o7p-8q9r-0s1t2u3v4w5x", "text": "function test(default a = 10) {}" }
      ]
    },
    {
      "id": "e8d7c6b5-a432-4f1e-0d9c-8b7a6f5e4d3c",
      "step": 10,
      "question": "What is the value of 'result' in this IIFE?",
      "codeSnippet": "let result = (function(x) {\n  return x * x;\n})(4);",
      "correctAnswerId": "3k4l5m6n-7o8p-4q9r-0s1t-2u3v4w5x6y7z",
      "explanation": "This is an Immediately Invoked Function Expression (IIFE). It executes immediately with the argument 4, returning 4 * 4, which is 16.",
      "answers": [
        { "id": "2j3k4l5m-6n7o-4p8q-9r0s-1t2u3v4w5x6y", "text": "4" },
        { "id": "3k4l5m6n-7o8p-4q9r-0s1t-2u3v4w5x6y7z", "text": "16" },
        { "id": "4l5m6n7o-8p9q-4r0s-1t2u-3v4w5x6y7z8a", "text": "undefined" },
        { "id": "5m6n7o8p-9q0r-4s1t-2u3v-4w5x6y7z8a9b", "text": "Function object" },
        { "id": "6n7o8p9q-0r1s-4t2u-3v4w-5x6y7z8a9b0c", "text": "ReferenceError" }
      ]
    },
    {
      "id": "c4d5e6f7-a8b9-4c0d-1e2f-3a4b5c6d7e8f",
      "step": 11,
      "question": "Which of the following is a valid arrow function?",
      "codeSnippet": null,
      "correctAnswerId": "7o8p9q0r-1s2t-4u3v-4w5x-6y7z8a9b0c1d",
      "explanation": "Arrow functions use the '=>' syntax. 'let f = () => {}' is the correct way to define one without parameters.",
      "answers": [
        { "id": "7o8p9q0r-1s2t-4u3v-4w5x-6y7z8a9b0c1d", "text": "let f = () => {}" },
        { "id": "8p9q0r1s-2t3u-4v4w-5x6y-7z8a9b0c1d2e", "text": "let f = function => {}" },
        { "id": "9q0r1s2t-3u4v-4w5x-6y7z-8a9b0c1d2e3f", "text": "let f = () -> {}" },
        { "id": "0r1s2t3u-4v5w-4x6y-7z8a-9b0c1d2e3f4g", "text": "let f = => {}" },
        { "id": "1s2t3u4v-5w6x-4y7z-8a9b-0c1d2e3f4g5h", "text": "let f = () => return 1" }
      ]
    },
    {
      "id": "b9c0d1e2-f3a4-4b5c-6d7e-8f9a0b1c2d3e",
      "step": 12,
      "question": "What will this code output?",
      "codeSnippet": "const greet = (name) => `Hi ${name}`;\nconsole.log(greet());",
      "correctAnswerId": "3u4v5w6x-7y8z-4a9b-0c1d-2e3f4g5h6i7j",
      "explanation": "If an argument is missing during a function call, the corresponding parameter is assigned 'undefined'. The template literal then evaluates to 'Hi undefined'.",
