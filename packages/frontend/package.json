{
  "name": "@rs-tandem/frontend",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch",
    "test:ui:coverage": "ng test --ui --coverage",
    "e2e": "docker-compose -f docker-compose.e2e.yml run --rm playwright",
    "e2e:update": "docker-compose -f docker-compose.e2e.yml run --rm -e PLAYWRIGHT_FLAGS=-u playwright",
    "e2e:show-report": "npx playwright show-report playwright/report",
    "i18n:find": "transloco-keys-manager find",
    "i18n:generate-types": "npx tsx scripts/generate-i18n-types.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "~21.1.4",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.1.4",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@rs-tandem/shared": "*",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@jsverse/transloco": "^8.2.1",
    "@jsverse/transloco-keys-manager": "^8.1.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.6",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^27.1.0",
    "socket.io-client": "^4.8.3",
    "stylelint": "^17.3.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vitest": "^4.0.8"
  }
}
